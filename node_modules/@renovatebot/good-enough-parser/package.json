{
  "name": "@renovatebot/good-enough-parser",
  "description": "Parse and query computer programs source code",
  "version": "2.0.1",
  "repository": "https://github.com/renovatebot/good-enough-parser.git",
  "author": "Sergei Zharinov",
  "contributors": [
    "Jason Kuhrt"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "type": "commonjs",
  "dependencies": {
    "@thi.ng/zipper": "1.0.3",
    "@types/moo": "0.5.10",
    "klona": "2.0.6",
    "moo": "0.5.3"
  },
  "devDependencies": {
    "@containerbase/semantic-release-pnpm": "1.4.1",
    "@renovate/eslint-plugin": "https://github.com/renovatebot/eslint-plugin#v0.0.5",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.17",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "8.10.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-only-warn": "1.2.1",
    "http-server": "14.1.1",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-junit": "16.0.0",
    "jest-watch-select-projects": "2.0.0",
    "jest-watch-suspend": "1.1.2",
    "jest-watch-typeahead": "3.0.1",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "pretty-quick": "4.2.2",
    "semantic-release": "25.0.3",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "upath": "2.0.1"
  },
  "scripts": {
    "lint": "run-s lint:*",
    "lint:types": "tsc --noEmit",
    "lint:eslint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:prettier": "prettier --check .",
    "fix": "run-s fix:*",
    "fix:eslint": "eslint . --ext .ts,.tsx --fix",
    "fix:prettier": "prettier --write .",
    "dev": "run-p dev:*",
    "dev:coverage": "http-server ./coverage/lcov-report",
    "build": "run-s clean build:*",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "test": "run-s lint test:*",
    "test:unit": "jest",
    "clean": "rm -rf dist node_modules/.cache coverage"
  }
}