{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "description": "Webgrip org default Renovate preset — strict, conservative defaults for all repositories. Graduated release soak times, per-type semantic commits and labels, OSV vulnerability alerts, and Merge Confidence badges included.",
    "extends": [
        "config:recommended",
        ":dependencyDashboard",
        ":semanticCommits",
        ":separateMultipleMajorReleases",
        ":enableVulnerabilityAlerts",
        ":timezone(Europe/Amsterdam)",
        "abandonments:recommended",
        "mergeConfidence:all-badges"
    ],
    "configMigration": true,
    "enabled": true,
    "timezone": "Europe/Amsterdam",
    "schedule": [
        "after 3am and before 7am every weekday",
        "every weekend"
    ],
    "updateNotScheduled": false,
    "fetchChangeLogs": "pr",
    "rebaseWhen": "behind-base-branch",
    "recreateWhen": "always",
    "rangeStrategy": "pin",
    "pinDigests": true,
    "separateMajorMinor": true,
    "separateMinorPatch": true,
    "separateMultipleMajor": true,
    "ignoreUnstable": true,
    "respectLatest": true,
    "rollbackPrs": true,
    "internalChecksFilter": "none",
    "prCreation": "not-pending",
    "prNotPendingHours": 2,
    "prHourlyLimit": 0,
    "prConcurrentLimit": 5,
    "branchConcurrentLimit": 10,
    "suppressNotifications": [
        "prIgnoreNotification"
    ],
    "labels": [
        "dependencies",
        "renovate"
    ],
    "semanticCommits": "enabled",
    "semanticCommitType": "chore",
    "semanticCommitScope": "deps",
    "automerge": false,
    "platformAutomerge": false,
    "assigneesFromCodeOwners": true,
    "reviewersFromCodeOwners": true,
    "dependencyDashboard": true,
    "dependencyDashboardTitle": "Renovate Dependency Dashboard",
    "dependencyDashboardAutoclose": true,
    "dependencyDashboardOSVVulnerabilitySummary": "unresolved",
    "osvVulnerabilityAlerts": true,
    "vulnerabilityAlerts": {
        "enabled": true,
        "labels": [
            "security",
            "dependencies",
            "renovate"
        ],
        "prCreation": "immediate",
        "schedule": [
            "at any time"
        ],
        "dependencyDashboardApproval": false
    },
    "lockFileMaintenance": {
        "enabled": true,
        "extends": [
            "schedule:monthly"
        ],
        "dependencyDashboardApproval": true
    },
    "prBodyNotes": [
        "{{#if isMajor}}⚠️ **Major update**: review upstream migration notes and rollout impact before merging.{{/if}}",
        "{{#if isVulnerabilityAlert}}🔒 **Security update**: prioritize review and verify the vulnerable component is actually deployed.{{/if}}",
        "{{#if isGroup}}📦 **Grouped update**: confirm the group is operationally coherent before merging.{{/if}}",
        "Merge Confidence badges are included where supported — low or neutral confidence warrants a manual impact check before merge."
    ],
    "packageRules": [
        {
            "description": "Require explicit dashboard approval for all normal updates",
            "matchUpdateTypes": [
                "major",
                "minor",
                "patch",
                "pin",
                "digest",
                "replacement",
                "rollback"
            ],
            "dependencyDashboardApproval": true
        },
        {
            "description": "Major updates — longest soak time, breaking-change label, feat! commits",
            "matchUpdateTypes": [
                "major"
            ],
            "minimumReleaseAge": "14 days",
            "automerge": false,
            "semanticCommitType": "feat",
            "commitMessagePrefix": "{{semanticCommitType}}({{semanticCommitScope}})!:",
            "commitMessageExtra": "( {{currentVersion}} ➔ {{newVersion}} )",
            "addLabels": [
                "type/major",
                "breaking-change"
            ]
        },
        {
            "description": "Minor updates — short soak time, feat commits",
            "matchUpdateTypes": [
                "minor"
            ],
            "minimumReleaseAge": "3 days",
            "semanticCommitType": "feat",
            "commitMessageExtra": "( {{currentVersion}} ➔ {{newVersion}} )",
            "addLabels": [
                "type/minor"
            ]
        },
        {
            "description": "Patch updates — minimal soak time, fix commits",
            "matchUpdateTypes": [
                "patch"
            ],
            "minimumReleaseAge": "1 day",
            "semanticCommitType": "fix",
            "commitMessageExtra": "( {{currentVersion}} ➔ {{newVersion}} )",
            "addLabels": [
                "type/patch"
            ]
        },
        {
            "description": "Digest-only updates — no changelog needed, chore commits",
            "matchUpdateTypes": [
                "digest"
            ],
            "semanticCommitType": "chore",
            "commitMessageExtra": "( {{currentDigestShort}} ➔ {{newDigestShort}} )",
            "fetchChangeLogs": "off",
            "addLabels": [
                "type/digest"
            ]
        },
        {
            "description": "Pin Docker image digests and require approval",
            "matchDatasources": [
                "docker"
            ],
            "pinDigests": true,
            "dependencyDashboardApproval": true,
            "addLabels": [
                "container"
            ]
        },
        {
            "description": "Pin GitHub Actions to immutable digests and treat workflow updates as CI-only",
            "matchManagers": [
                "github-actions"
            ],
            "pinDigests": true,
            "dependencyDashboardApproval": true,
            "semanticCommitType": "ci",
            "semanticCommitScope": "actions",
            "commitMessagePrefix": "{{semanticCommitType}}({{semanticCommitScope}}):",
            "addLabels": [
                "github-actions"
            ]
        },
        {
            "description": "Security fixes bypass the normal approval gate and open immediately",
            "matchUpdateTypes": [
                "vulnerability"
            ],
            "dependencyDashboardApproval": false,
            "prCreation": "immediate",
            "schedule": [
                "at any time"
            ],
            "addLabels": [
                "security"
            ]
        },
        {
            "description": "Do not apply stability-days soak time to shared Renovate preset updates",
            "matchPackageNames": [
                "webgrip/renovate-config"
            ],
            "minimumReleaseAge": "0 days"
        },
        {
            "description": "Never digest-pin the shared preset reference. It is already pinned to a protected semver release tag; the global pinDigests=true otherwise makes Renovate try to rewrite 'github>webgrip/renovate-config#vX.Y.Z' to a commit SHA, the replacement never applies ('Digest is not updated'), and the whole pin-dependencies branch aborts with 'Error updating branch: update failure' on every run.",
            "matchPackageNames": [
                "webgrip/renovate-config"
            ],
            "pinDigests": false
        },
        {
            "description": "Disable peer dependency updates to avoid range-only churn",
            "matchDepTypes": [
                "peerDependencies"
            ],
            "enabled": false
        },
        {
            "description": "Never digest-pin mise-managed tools. The mise manager cannot write digests into .mise.toml aqua/backend entries — the replace never applies ('Digest is not updated') and, like the preset-reference case above, the single failed dep aborts the whole grouped branch ('Error updating branch: update failure' on renovate/mise-tools). Version pins remain enabled.",
            "matchManagers": [
                "mise"
            ],
            "matchUpdateTypes": [
                "pinDigest",
                "digest"
            ],
            "enabled": false,
            "pinDigests": false
        },
        {
            "description": "Approval IS the gate: update types that require a dashboard tick skip the release-age soak. Renovate does not persist approvals — a tick on a soak-blocked update is consumed and silently discarded, so double-gating just eats clicks. Soak still applies wherever a repo-level rule re-adds minimumReleaseAge on unattended automerge paths (repo config is applied after presets).",
            "matchUpdateTypes": [
                "major",
                "minor",
                "patch",
                "pin",
                "digest",
                "replacement",
                "rollback"
            ],
            "minimumReleaseAge": "0 days"
        }
    ]
}
