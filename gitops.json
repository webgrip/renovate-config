{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Webgrip GitOps Renovate overlay. Extends selected home-operations presets for Kubernetes/homelab extraction, then keeps Webgrip-specific Flux OCI digest handling and PR polish. Extend after the default org preset.",
  "extends": [
    "github>home-operations/renovate-presets//config/managerFilePatterns.json5#1.3.1",
    "github>home-operations/renovate-presets//config/registryAliases.json5#1.3.1",
    "github>home-operations/renovate-presets//managers/annotated.json5#1.3.1",
    "github>home-operations/renovate-presets//managers/cnpg.json5#1.3.1",
    "github>home-operations/renovate-presets//managers/grafanaDashboards.json5#1.3.1",
    "github>home-operations/renovate-presets//managers/oci.json5#1.3.1",
    "github>home-operations/renovate-presets//managers/talosFactory.json5#1.3.1",
    "github>home-operations/renovate-presets//overrides/changelogs.json5#1.3.1",
    "github>home-operations/renovate-presets//overrides/helmfile.json5#1.3.1",
    "github>home-operations/renovate-presets//overrides/mise.json5#1.3.1",
    "github>home-operations/renovate-presets//overrides/renovateOperator.json5#1.3.1",
    "github>home-operations/renovate-presets//policies/semanticCommits.json5#1.3.1",
    "github>home-operations/renovate-presets//versioning/llamacpp.json5#1.3.1",
    "github>home-operations/renovate-presets//versioning/phanpy.json5#1.3.1",
    "github>home-operations/renovate-presets//versioning/searxng.json5#1.3.1"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Process Flux OCIRepository tags; digest fields should be refreshed by a repo-local post-upgrade task when used.",
      "managerFilePatterns": [
        "/(^|/)kubernetes/apps/.+/ocirepository\\.ya?ml(?:\\.j2)?$/"
      ],
      "matchStrings": [
        "kind:\\s*OCIRepository[\\s\\S]*?ref:\\s*\\n[\\s\\S]*?tag:\\s*(?<currentValue>\\S+)[\\s\\S]*?url:\\s*oci://(?<depName>\\S+)",
        "kind:\\s*OCIRepository[\\s\\S]*?url:\\s*oci://(?<depName>\\S+)[\\s\\S]*?ref:\\s*\\n[\\s\\S]*?tag:\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Manage Flux OCIRepository tags without asking Renovate to calculate digest-only OCI Helm chart updates.",
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        "kubernetes/apps/**/ocirepository.yaml",
        "kubernetes/apps/**/ocirepository.yml"
      ],
      "matchDatasources": [
        "docker"
      ],
      "groupName": "Flux OCI Helm charts",
      "separateMinorPatch": true,
      "pinDigests": false
    },
    {
      "description": "Disable digest-only and pin-digest updates for Flux OCIRepository custom regex deps; repo-local post-upgrade tasks own spec.ref.digest.",
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        "kubernetes/apps/**/ocirepository.yaml",
        "kubernetes/apps/**/ocirepository.yml"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "pinDigest",
        "digest"
      ],
      "enabled": false
    },
    {
      "description": "Disable Helmfile OCI Helm chart digest pinning; bootstrap-only Helmfiles are usually not reconciled by Flux.",
      "matchManagers": [
        "helmfile"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "pinDigest",
        "digest"
      ],
      "pinDigests": false,
      "enabled": false
    },
    {
      "description": "Pin GitOps-managed container image digests by default.",
      "matchManagers": [
        "helm-values",
        "kustomize",
        "kubernetes"
      ],
      "matchDatasources": [
        "docker"
      ],
      "groupName": "GitOps container images",
      "pinDigests": true
    },
    {
      "description": "Add the Webgrip Grafana dashboard label on top of the upstream home-operations PR polish.",
      "matchDatasources": [
        "custom.grafana-dashboards"
      ],
      "addLabels": [
        "renovate/grafana-dashboard"
      ]
    },
    {
      "description": "Reserved terminal rule to keep future GitOps-specific PR polish appended after extraction rules.",
      "matchManagers": [
        "custom.regex"
      ],
      "semanticCommitScope": "gitops"
    }
  ]
}
