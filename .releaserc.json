{
    "$schema": "https://json.schemastore.org/semantic-release.json",
    "branches": [
        "main",
        {
            "name": "next",
            "channel": "rc",
            "prerelease": "rc"
        }
    ],
    "tagFormat": "v${version}",
    "plugins": [
        [
            "@semantic-release/commit-analyzer",
            {
                "preset": "conventionalcommits",
                "releaseRules": [
                    {
                        "breaking": true,
                        "release": "major"
                    },
                    {
                        "revert": true,
                        "release": "patch"
                    },
                    {
                        "type": "feat",
                        "release": "minor"
                    },
                    {
                        "type": "fix",
                        "release": "patch"
                    },
                    {
                        "type": "chore",
                        "scope": "deps",
                        "release": "patch"
                    },
                    {
                        "type": "chore",
                        "release": false
                    },
                    {
                        "type": "refactor",
                        "release": "patch"
                    },
                    {
                        "type": "perf",
                        "release": "patch"
                    },
                    {
                        "type": "ci",
                        "release": false
                    },
                    {
                        "type": "docs",
                        "release": false
                    },
                    {
                        "type": "style",
                        "release": false
                    },
                    {
                        "type": "test",
                        "release": false
                    },
                    {
                        "type": "build",
                        "release": false
                    }
                ],
                "parserOpts": {
                    "noteKeywords": [
                        "BREAKING CHANGE",
                        "BREAKING CHANGES",
                        "BREAKING"
                    ]
                }
            }
        ],
        [
            "@semantic-release/release-notes-generator",
            {
                "preset": "conventionalcommits",
                "presetConfig": {
                    "types": [
                        {
                            "type": "feat",
                            "section": "🚀 New Preset Rules & Features"
                        },
                        {
                            "type": "fix",
                            "section": "🐛 Rule Corrections & Fixes"
                        },
                        {
                            "type": "chore",
                            "section": "🔧 Maintenance",
                            "hidden": false
                        },
                        {
                            "type": "docs",
                            "section": "📚 Documentation",
                            "hidden": false
                        },
                        {
                            "type": "ci",
                            "section": "⚙️ CI / CD",
                            "hidden": false
                        },
                        {
                            "type": "refactor",
                            "section": "♻️ Refactoring",
                            "hidden": false
                        },
                        {
                            "type": "perf",
                            "section": "⚡ Performance"
                        },
                        {
                            "type": "revert",
                            "section": "⏪ Reverts"
                        },
                        {
                            "type": "build",
                            "hidden": true
                        },
                        {
                            "type": "style",
                            "hidden": true
                        },
                        {
                            "type": "test",
                            "hidden": true
                        }
                    ]
                },
                "writerOpts": {
                    "commitsSort": [
                        "subject",
                        "scope"
                    ]
                }
            }
        ],
        [
            "@semantic-release/changelog",
            {
                "changelogFile": "CHANGELOG.md",
                "changelogTitle": "# Changelog\n\nAll notable changes to the **Webgrip shared Renovate preset** are documented here.\nThis project uses [Semantic Versioning](https://semver.org/) and [Conventional Commits](https://www.conventionalcommits.org/).\n\nConsumers should **always pin to a release tag**:\n```json\n{ \"extends\": [\"github>webgrip/renovate-config#vX.Y.Z\"] }\n```\n\n> **Breaking changes** (`feat!`) bump the major version and include migration notes in the release body.\n> Subscribers to this repo's releases will be notified automatically."
            }
        ],
        [
            "@semantic-release/exec",
            {
                "verifyReleaseCmd": "npm run validate && echo '✅ All presets passed validation'"
            }
        ],
        [
            "@semantic-release/git",
            {
                "assets": [
                    "CHANGELOG.md"
                ],
                "message": "chore(release): v${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
            }
        ],
        [
            "@semantic-release/github",
            {
                "assets": [
                    {
                        "path": "default.json",
                        "name": "default.json",
                        "label": "Default preset (v${nextRelease.version})"
                    },
                    {
                        "path": "grouped.json",
                        "name": "grouped.json",
                        "label": "Grouped overlay (v${nextRelease.version})"
                    },
                    {
                        "path": "safe-automerge.json",
                        "name": "safe-automerge.json",
                        "label": "Safe-automerge overlay (v${nextRelease.version})"
                    },
                    {
                        "path": "gitops.json",
                        "name": "gitops.json",
                        "label": "GitOps overlay (v${nextRelease.version})"
                    }
                ],
                "successComment": "🎉 This change ships in [v${nextRelease.version}](${nextRelease.url}).\n\nUpdate consuming repos to adopt it:\n\n```json\n{\n  \"extends\": [\"github>webgrip/renovate-config#v${nextRelease.version}\"]\n}\n```",
                "failComment": "The release workflow failed to publish a new version. Check the [Actions tab](https://github.com/webgrip/renovate-config/actions) for details.",
                "releasedLabels": [
                    "released"
                ],
                "addReleases": "bottom",
                "draftRelease": false
            }
        ]
    ]
}
